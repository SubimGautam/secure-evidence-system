NODE_ENV=development
PORT=4000

# Points at the Postgres container's published port (5433, not 5432 — see
# ../docker-compose.yml) so `npm run dev` can run outside Docker while still
# using `docker compose up postgres` for the database. Inside Docker Compose,
# the backend container instead gets DATABASE_URL injected pointing at the
# "postgres" service name on the internal network.
DATABASE_URL="postgresql://evidence_app:devlocalonly_change_me@localhost:5433/evidence_custody?schema=public"

# Optional — the app queries through this role at runtime instead of
# DATABASE_URL when it's set (see lib/prisma.js and
# prisma/init/01-create-runtime-role.sh). Left unset here: a local dev
# Postgres you set up by hand only has the one role anyway, so there's
# nothing to separate. docker-compose.yml sets this explicitly.
# RUNTIME_DATABASE_URL="postgresql://evidence_runtime:...@localhost:5433/evidence_custody?schema=public"

CORS_ORIGIN="http://localhost:5173"

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-96-char-random-hex-string"
JWT_ACCESS_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# AES-256-GCM master key for encrypting TOTP secrets and evidence files at
# rest — must be exactly 32 bytes (64 hex chars). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="replace-with-a-64-char-random-hex-string"

# Where encrypted evidence files are written. In Docker this is a named
# volume mount (see ../docker-compose.yml); for local `npm run dev` it's a
# plain folder on disk, gitignored.
EVIDENCE_STORAGE_PATH="./storage/evidence-files"

# hCaptcha bot-mitigation on register/login (middleware/captcha.js), on top
# of rate limiting + account lockout. Leave disabled for local dev/CI unless
# you've registered a free hCaptcha site and have real keys — enabling this
# without CAPTCHA_SECRET_KEY set fails startup validation on purpose (env.js).
CAPTCHA_ENABLED="false"
# CAPTCHA_SECRET_KEY="replace-with-your-hcaptcha-secret-key"
