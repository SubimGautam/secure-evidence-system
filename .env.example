# Used by docker-compose.yml. Copy to .env and adjust before running
# `docker compose up`. Never commit the real .env file.

POSTGRES_USER=evidence_app
POSTGRES_PASSWORD=devlocalonly_change_me
POSTGRES_DB=evidence_custody

# A separate, ordinary (non-owner, non-superuser) role the app queries as at
# runtime, distinct from POSTGRES_USER (the schema owner) — see
# backend/prisma/init/01-create-runtime-role.sh for why this matters for the
# audit_logs immutability policy specifically.
# node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
POSTGRES_RUNTIME_USER=evidence_runtime
POSTGRES_RUNTIME_PASSWORD=replace-with-a-random-password

# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-96-char-random-hex-string
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace-with-a-64-char-random-hex-string

# hCaptcha (https://www.hcaptcha.com) — optional. Leave both unset/false and
# the app runs with CAPTCHA disabled (default). Set all three to turn it on
# for a real deployment; SITE_KEY is public (baked into the frontend build),
# SECRET_KEY is not.
CAPTCHA_ENABLED=false
# CAPTCHA_SECRET_KEY=replace-with-your-hcaptcha-secret-key
# VITE_HCAPTCHA_SITE_KEY=replace-with-your-hcaptcha-site-key
